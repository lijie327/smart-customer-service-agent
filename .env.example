# ===== 大模型（必填）=====
DASHSCOPE_API_KEY=your_key_here
LLM_MODEL=qwen-max

# ===== 服务监听 =====
HOST=0.0.0.0
PORT=8000

# ===== Redis 会话记忆（可选，未配置时自动降级到内存）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== 数据层 / 路径（Docker 部署通常用卷挂载，无需改）=====
# SQLite 数据库文件位置（默认 <项目>/data/smart_cs.db）
# DB_PATH=/app/data/smart_cs.db
# FAISS 索引目录（默认 <项目>/data/faq_index）
# FAQ_INDEX_PATH=/app/data/faq_index
# 上传目录（默认 <项目>/uploads）
# UPLOAD_DIR=/app/uploads

# ===== CORS（生产建议收口到具体前端域名，逗号分隔）=====
# ALLOWED_ORIGINS=https://your-domain.com
# 仅当 ALLOWED_ORIGINS 不含 * 时才可设为 true
ALLOW_CREDENTIALS=false
